                        </Grid>
                        <Button x:Name="btnBackupStart" Content="Start" HorizontalAlignment="Left" Margin="165,104,0,0" VerticalAlignment="Top" Width="100" Height="40" Click="btnBackupStart_Click"/>
                        <Label Content="Backup" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </Grid>
                    <Grid HorizontalAlignment="Left" Height="154" Margin="290,10,0,0" VerticalAlignment="Top" Width="275" Background="#FF303030">
                        <Grid.Effect>
                            <DropShadowEffect/>
                        </Grid.Effect>
                        <Label Content="Restore" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Grid HorizontalAlignment="Left" Height="113" Margin="10,31,0,0" VerticalAlignment="Top" Width="143" Background="#FF404040">
                            <Grid.Effect>
                                <DropShadowEffect/>
                            </Grid.Effect>
                            <Label Content="Target Data" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                            <CheckBox x:Name="cbUnitDataRestore" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,31,0,0" Content="Board Data" IsChecked="True" />
                            <CheckBox x:Name="cbHcDataRestore" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,51,0,0" Content="Uniformity H Data" IsChecked="True" />
                            <CheckBox x:Name="cbLcDataRestore" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,71,0,0" Content="Uniformity L Data" />
                            <!--<CheckBox x:Name="cbAgingDataRestore" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,91,0,0" Content="Aging Data" />-->
                        </Grid>
                        <Label Content="Target Folder" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="162,31,0,0"/>
                        <ComboBox x:Name="cmbxRestoreTarget" HorizontalAlignment="Left" Margin="185,62,0,0" VerticalAlignment="Top" Width="80" SelectedIndex="0" >
                            <ComboBoxItem Content="Previous"/>
