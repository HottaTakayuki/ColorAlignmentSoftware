                        </ComboBox>
                        <Button x:Name="btnRestoreStart" Content="Start" HorizontalAlignment="Left" Margin="165,104,0,0" VerticalAlignment="Top" Width="100" Height="40" Click="btnRestoreStart_Click"/>
                    </Grid>
                    <Grid HorizontalAlignment="Left" Height="154" Margin="570,10,0,0" VerticalAlignment="Top" Width="168" Background="#FF303030">
                        <Grid.Effect>
                            <DropShadowEffect/>
                        </Grid.Effect>
                        <Label Content="Replace" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <Button x:Name="btnReplace" Content="Start" HorizontalAlignment="Left" Margin="58,104,0,0" VerticalAlignment="Top" Width="100" Height="40" Click="btnReplace_Click"/>
                        <RadioButton x:Name="rbCellReplace" Content="Module" HorizontalAlignment="Left" Margin="10,31,0,0" VerticalAlignment="Top" IsChecked="True" Checked="rbCellReplace_Checked"/>
                        <RadioButton x:Name="rbUCBoard" Content="RCS Board (Cabinet)" HorizontalAlignment="Left" Margin="10,51,0,0" VerticalAlignment="Top" Checked="rbUCBoard_Checked"/>
                        <RadioButton x:Name="rbCpuReplace" Content="CPU Board (Controller)" HorizontalAlignment="Left" Margin="10,71,0,0" VerticalAlignment="Top" Checked="rbUCBoard_Checked" Height="15"/>
                    </Grid>
                    <Grid HorizontalAlignment="Left" Height="154" Margin="743,10,0,0" VerticalAlignment="Top" Width="168" Background="#FF303030">
                        <Grid.Effect>
                            <DropShadowEffect/>
