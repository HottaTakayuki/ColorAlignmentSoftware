                <MenuItem x:Name="miAbout" Header="About Color Uniformity Alignment Software" Click="miAbout_Click"/>
            </MenuItem>
        </Menu>
        <TabControl x:Name="tcMain" Margin="0" Background="#FF202020" Grid.Row="1" SelectedIndex="{Binding TabSelectIndex}" SelectionChanged="tcMain_SelectionChanged" Foreground="White" Grid.ColumnSpan="3">
            <TabItem x:Name="tiData" Header="Data">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFC0C0C0" Offset="0"/>
                        <GradientStop Color="#FF606060" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid x:Name="gdData" Background="#FF202020" >
                    <Grid HorizontalAlignment="Left" Height="154" Margin="10,10,0,0" VerticalAlignment="Top" Width="275" Background="#FF303030">
                        <Grid.Effect>
                            <DropShadowEffect/>
                        </Grid.Effect>
                        <Grid HorizontalAlignment="Left" Height="113" Margin="10,31,0,0" VerticalAlignment="Top" Width="143" Background="#FF404040">
                            <Grid.Effect>
                                <DropShadowEffect/>
