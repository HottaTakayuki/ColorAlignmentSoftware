<Window x:Class="CAS.WindowMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Complete" Height="180" Width="300" WindowStartupLocation="CenterScreen" Topmost="True" Icon="/Resources/CLED_CAS_App_Icon_170327.ico" ResizeMode="CanResizeWithGrip">
    <Grid Background="#FF202020">
        <TextBlock x:Name="tbMessage" HorizontalAlignment="Left" Margin="65,20,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Text="Test Test Test Test Test Test Test Test Test Test " Foreground="White" FontSize="14"/>
        <Button x:Name="btnOK" Content="OK" HorizontalAlignment="Center" Margin="0,91,0,10" VerticalAlignment="Bottom" Width="100" Height="32" Click="btnOK_Click" FontSize="14" />
        <Button x:Name="btn2" Content="No" HorizontalAlignment="Left" Margin="202,91,-8,10" VerticalAlignment="Bottom" Width="100" Height="32" Click="btn2_Click" Visibility="Collapsed" FontSize="14" />
        <Image x:Name="imIcon" HorizontalAlignment="Left" Height="35" Margin="20,20,0,0" VerticalAlignment="Top" Width="35"/>
    </Grid>
</Window>
