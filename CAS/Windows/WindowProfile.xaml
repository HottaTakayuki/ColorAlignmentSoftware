<Window x:Class="CAS.WindowProfile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layout Setting" Height="160" Width="310" Icon="/Resources/CLED_CAS_App_Icon_170327.ico" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#FF202020">
        <Button x:Name="btnOpenProfile" Content="Open Profile" HorizontalAlignment="Left" Margin="10,0,0,12" VerticalAlignment="Bottom" Width="130" Height="40" Click="btnOpenProfile_Click"/>
        <TextBlock HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="52" Width="274" Foreground="White">Can not open last profile !<LineBreak /> 
            Please choose Open Profile or Input Layout Info.
        </TextBlock>
        <Button x:Name="btnInputLayout" Content="Input Layout Info." HorizontalAlignment="Right" Margin="0,0,10,12" VerticalAlignment="Bottom" Width="130" Height="40" Click="btnInputLayout_Click" HorizontalContentAlignment="Center"/>

    </Grid>
</Window>
