<Window x:Class="CAS.WindowSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAS Setting" Height="176" Width="260" ResizeMode="NoResize" Icon="/Resources/CLED_CAS_App_Icon_170327.ico" WindowStartupLocation="CenterScreen">
    <Grid Background="#FF202020">
        <Grid HorizontalAlignment="Left" Height="71" Margin="10,10,0,0" VerticalAlignment="Top" Width="160" Background="#FF303030">
            <Grid.Effect>
                <DropShadowEffect/>
            </Grid.Effect>
            <Label Content="CA-410" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White"/>
            <Label Content="Channel" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Margin="10,31,0,0"/>
            <ComboBox x:Name="cmbxChannel" HorizontalAlignment="Left" Margin="68,35,0,0" VerticalAlignment="Top" Width="80"/>
        </Grid>
        <Button x:Name="btnOK" Content="OK" HorizontalAlignment="Left" Margin="20,97,0,0" VerticalAlignment="Top" Width="100" Height="30" Foreground="#FF008BFF" Click="btnOK_Click"/>
        <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left" Margin="124,97,0,0" VerticalAlignment="Top" Width="100" Height="30" Foreground="#FFFF0074" Click="btnCancel_Click"/>
    </Grid>
</Window>
