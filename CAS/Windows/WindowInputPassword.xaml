<Window x:Class="CAS.WindowInputPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layout Setting (3)" Height="130" Width="310" Icon="/Resources/CLED_CAS_App_Icon_170327.ico" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#FF202020">
        <TextBlock x:Name="inputPasswordMsg" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="272" Foreground="White" Text="Please input ADCP password."/>
        <Button x:Name="btnInputPasswordOK" Content="OK" HorizontalAlignment="Left" Margin="192,0,0,10" VerticalAlignment="Bottom" Width="90" Height="40" Click="btnInputPasswordOK_Click" />
        <PasswordBox x:Name="txbPw" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="35,0,0,18" Width="120" Height="22" KeyUp="inputPassword_KeyUp" />
    </Grid>
</Window>
