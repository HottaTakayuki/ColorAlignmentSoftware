<Window x:Class="CAS.WindowUnitError"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CABINET Error Status" Height="342" Width="310" ResizeMode="NoResize" Icon="/Resources/CLED_CAS_App_Icon_170327.ico">
    <Grid Background="#FF202020">
        <Label x:Name="lbUnit" Content="(X,Y) Cx-xx-xx" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.553,-0.192" Foreground="White"/>
        <Label Content="Error :" HorizontalAlignment="Left" Margin="10,41,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.553,-0.192" Foreground="White"/>
        <ListBox x:Name="lbxError" HorizontalAlignment="Left" Height="170" Margin="10,72,0,0" VerticalAlignment="Top" Width="274" ScrollViewer.VerticalScrollBarVisibility="Visible" Background="#FF404040" BorderBrush="Black" Foreground="White"/>
        <Button x:Name="btnClose" Content="Close" HorizontalAlignment="Left" Margin="209,254,0,10" VerticalAlignment="Bottom" Width="75" Height="25" Click="btnClose_Click"/>
    </Grid>

</Window>
