<Window x:Class="CAS.WindowControllerIP"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Layout Setting (2)" Height="130" Width="310" Icon="/Resources/CLED_CAS_App_Icon_170327.ico" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Background="#FF202020">
        <TextBlock x:Name="txbMesssage" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="272" Foreground="White" Text="Please input IP address."/>
        <Button x:Name="btnControllerIPOK" Content="OK" HorizontalAlignment="Left" Margin="192,0,0,10" VerticalAlignment="Bottom" Width="90" Height="40" Click="btnControllerIPOK_Click" />
        <TextBox x:Name="txbIP" HorizontalAlignment="Left" Height="23" Margin="35,0,0,18" TextWrapping="Wrap" VerticalAlignment="Bottom" Width="120"  x:FieldModifier="public" KeyUp="txbIP_KeyUp"/>

    </Grid>
</Window>
