<Window x:Class="CAS.WindowCpuReplaceInputIP"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace CPU Board" Height="130" Width="300" Topmost="True" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" Icon="/Resources/CLED_CAS_App_Icon_170327.ico">
    <Grid Background="#FF202020">
        <TextBlock x:Name="txbMesssage" HorizontalAlignment="Left" Margin="10,10,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Height="24" Width="272" Foreground="White" Text="Enter Controller IP Address"/>
        <Button x:Name="btnOK" Content="OK" HorizontalAlignment="Left" Margin="214,51,0,0" VerticalAlignment="Top" Width="60" Height="30" Click="btnOK_Click" />
        <TextBox x:Name="txbIP" HorizontalAlignment="Left" Height="23" Margin="83,39,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"  x:FieldModifier="public" KeyUp="txbSerial_KeyUp" Text="192.168.6.10"/>        
    </Grid>
</Window>
