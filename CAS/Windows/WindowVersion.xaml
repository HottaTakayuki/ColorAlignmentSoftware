<Window x:Class="CAS.WindowVersion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Color Uniformity Alignment Software" Height="210" Width="430" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Icon="/Resources/CLED_CAS_App_Icon_170327.ico">
    <Grid Background="#FF202020">
        <Canvas HorizontalAlignment="Left" Height="100" Margin="31,34,0,0" VerticalAlignment="Top" Width="100">
            <Canvas.Background>
                <ImageBrush ImageSource="/Resources/CLED_CAS_App_Icon_170327.ico"/>
            </Canvas.Background>
        </Canvas>
        <Label Content="Color Uniformity Alignment Software" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Margin="159,34,0,0"/>
        <Label x:Name="txbVersion" Content="Version 1.0.0.0" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Margin="159,65,0,0"/>
        <Label x:Name="lbCopyright" Content="Copyright 2021, 2022 Sony Corporation" HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="White" Margin="159,96,0,0"/>
        <Button x:Name="btnOK" Content="OK" HorizontalAlignment="Right" Margin="0,0,20,12" VerticalAlignment="Bottom" Width="80" Height="30" Click="btnOK_Click"/>
    </Grid>
</Window>
